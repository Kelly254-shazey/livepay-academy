NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://livegate:livegate@mysql:3306/livegate_nodejs
REDIS_URL=redis://redis:6379
CORS_ORIGIN=*
APP_BASE_URL=http://localhost:5173
JWT_ACCESS_SECRET=your-secret-key-min-32-characters-for-production
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-characters-for-production
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_PROVIDER=log
EMAIL_FROM=no-reply@livegate.app
RESEND_API_BASE_URL=https://api.resend.com
RESEND_API_KEY=
EMAIL_CODE_TTL_MINUTES=15
PASSWORD_RESET_CODE_TTL_MINUTES=30
GOOGLE_CLIENT_ID=
INTERNAL_API_KEY=your-internal-api-key-change-in-production
JAVA_FINANCE_URL=http://java-service:8080
PYTHON_INTELLIGENCE_URL=http://python-service:8000
STREAMING_PROVIDER_BASE_URL=http://streaming-provider-placeholder.internal
STREAMING_PROVIDER_API_KEY=replace-me
DEFAULT_CURRENCY=USD
SWAGGER_ENABLED=true
