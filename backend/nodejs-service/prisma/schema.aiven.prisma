generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model LearningClass {
  id          String        @id @default(uuid())
  creatorId   String
  categoryId  String?
  title       String
  description String?       @db.Text
  price       Decimal       @db.Decimal(12, 2)
  currency    String        @default("USD")
  isPaid      Boolean       @default(true)
  status      ClassStatus   @default(draft)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  category    category?     @relation(fields: [categoryId], references: [id])
  creator     user          @relation("UserClasses", fields: [creatorId], references: [id], onDelete: NoAction)
  classlesson classlesson[]
  enrollment  enrollment[]

  @@index([creatorId, status])
  @@index([categoryId, startsAt])
  @@map("classes")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model accessgrant {
  id                                 String                 @id
  userId                             String
  grantedById                        String?
  targetType                         accessgrant_targetType
  targetId                           String
  status                             accessgrant_status     @default(active)
  sourceReference                    String?                @unique(map: "AccessGrant_sourceReference_key")
  price                              Decimal?               @db.Decimal(12, 2)
  currency                           String?
  riskScore                          Decimal?               @db.Decimal(5, 2)
  expiresAt                          DateTime?
  createdAt                          DateTime               @default(now())
  updatedAt                          DateTime
  user_accessgrant_grantedByIdTouser user?                  @relation("accessgrant_grantedByIdTouser", fields: [grantedById], references: [id], map: "AccessGrant_grantedById_fkey")
  user_accessgrant_userIdTouser      user                   @relation("accessgrant_userIdTouser", fields: [userId], references: [id], onDelete: Cascade, map: "AccessGrant_userId_fkey")
  enrollment                         enrollment[]

  @@index([grantedById], map: "AccessGrant_grantedById_fkey")
  @@index([targetType, targetId, status], map: "AccessGrant_targetType_targetId_status_idx")
  @@index([userId, targetType, targetId, status], map: "AccessGrant_userId_targetType_targetId_status_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model auditlog {
  id             String                  @id
  actorId        String?
  actorRole      auditlog_actorRole?
  action         String
  resource       String
  resourceId     String?
  ipAddress      String?
  metadata       String?                 @db.LongText
  createdAt      DateTime                @default(now())
  actionCategory auditlog_actionCategory @default(admin)
  resourceType   String?
  status         String                  @default("success")
  statusCode     Int?
  description    String?
  userAgent      String?
  changes        String?                 @db.LongText
  errorMessage   String?
  duration       Int?
  timestamp      DateTime                @default(now())
  user           user?                   @relation(fields: [actorId], references: [id], map: "AuditLog_actorId_fkey")

  @@index([actionCategory, status], map: "AuditLog_actionCategory_status_idx")
  @@index([action, createdAt], map: "AuditLog_action_createdAt_idx")
  @@index([action, timestamp], map: "AuditLog_action_timestamp_idx")
  @@index([actorId, timestamp], map: "AuditLog_actorId_timestamp_idx")
  @@index([resourceType, resourceId], map: "AuditLog_resourceType_resourceId_idx")
  @@index([resource, resourceId], map: "AuditLog_resource_resourceId_idx")
  @@index([status], map: "AuditLog_status_idx")
  @@index([timestamp], map: "AuditLog_timestamp_idx")
}

model authidentity {
  id             String   @id @db.VarChar(100)
