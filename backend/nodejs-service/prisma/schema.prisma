generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  viewer
  creator
  moderator
  admin
}

enum AuthProvider {
  local
  google
}

enum OneTimeCodePurpose {
  email_verification
  password_reset
}

enum CreatorVerificationStatus {
  pending
  approved
  rejected
  suspended
}

enum CategoryStatus {
  active
  archived
}

enum LiveSessionStatus {
  draft
  scheduled
  published
  live
  ended
  cancelled
  suspended
}

enum LiveVisibility {
  public
  followers_only
  private
}

enum PremiumContentStatus {
  draft
  published
  archived
  suspended
}

enum ClassStatus {
  draft
  published
  archived
  suspended
}

enum NotificationType {
  live_reminder
  purchase
  creator_announcement
  system_alert
  moderation
}

enum AccessGrantTargetType {
  live_session
  premium_content
  class
  lesson
  private_live_invite
}

enum AccessGrantStatus {
  active
  revoked
  expired
  pending_review
}

enum ReportTargetType {
  live_session
  premium_content
  class
  user
  message
}

enum ModerationStatus {
  open
  under_review
  resolved
  dismissed
}

enum EnrollmentStatus {
  pending
  active
  refunded
  cancelled
  completed
}

enum ReviewTargetType {
  creator
  live_session
  premium_content
  class
}

enum VerificationReviewDecision {
  approved
  rejected
  needs_changes
}

enum LiveChatMessageStatus {
  active
  hidden
  removed
}

enum ModerationActionTargetType {
  user
  creator_profile
  live_session
  premium_content
  class
  live_chat_message
  review
  report
}

enum ModerationActionType {
  creator_approved
  creator_rejected
  creator_suspended
  account_suspended
  account_restored
  content_suspended
  content_restored
  message_removed
  report_resolved
  report_dismissed
}

enum PaymentMethodType {
  credit_card
  debit_card
  paypal
  bank_transfer
  mobile_money
  digital_wallet
}

enum PaymentProvider {
  stripe
  paypal
  wise
  mpesa
  flutterwave
  razorpay
}

enum AuditActionCategory {
  auth
  payment
  content_access
  session
  security
  moderation
  admin
}

model User {
  id                      String              @id @default(uuid())
  email                   String              @unique
  username                String              @unique
  passwordHash            String?
  firstName               String
  lastName                String
  avatarUrl               String?
  dateOfBirth             DateTime?           @db.Date
  gender                  String?
  customGender            String?
  emailVerifiedAt         DateTime?
  profileCompletedAt      DateTime?
  lastLoginAt             DateTime?
  role                    UserRole            @default(viewer)
  country                 String?             @db.Char(2) // ISO 3166-1 alpha-2 country code
  countryDetectedAt       DateTime?
  ipAddress               String?
  preferredCurrency       String?             @db.Char(3) // ISO 4217 currency code
  clerkId                 String?             @unique
  clerkMetadata           Json?
  settings                Json?
  notificationPreferences Json?
  isSuspended             Boolean             @default(false)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  creatorProfile          CreatorProfile?
  identities              AuthIdentity[]
  paymentMethods          PaymentMethod[]
  oneTimeCodes            OneTimeCode[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  liveSessions            LiveSession[]       @relation("UserLiveSessions")
  premiumContents         PremiumContent[]    @relation("UserPremiumContents")
  classes                 LearningClass[]     @relation("UserClasses")
  createdCategories       Category[]          @relation("CategoryCreatedBy")
  following               Follow[]            @relation("Follower")
  followers               Follow[]            @relation("CreatorFollower")
  notifications           Notification[]
  accessGrants            AccessGrant[]       @relation("AccessGrantUser")
  grantedAccess           AccessGrant[]       @relation("AccessGrantGrantor")
  participantRecords      LiveParticipant[]
  enrollments             Enrollment[]
  auditActorLogs          AuditLog[]          @relation("AuditActor")
  sessionAuditLogs        SessionAuditLog[]
  paymentAuditLogs        PaymentAuditLog[]
  contentAccessAuditLogs  ContentAccessAuditLog[]
  creatorVerificationReviews CreatorVerificationReview[] @relation("CreatorVerificationReviewer")
  liveChatMessages        LiveChatMessage[]
  moderationActions       ModerationAction[]  @relation("ModerationActor")
  reviews                 Review[]
  reports                 Report[]

  @@map("user")
}

model AuthIdentity {
  id             String       @id @default(uuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  email          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
  @@index([email])

  @@map("authidentity")
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])

  @@map("refreshtoken")
}

model OneTimeCode {
  id         String             @id @default(uuid())
  userId     String
  purpose    OneTimeCodePurpose
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime           @default(now())
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, expiresAt])
  @@index([purpose, codeHash])

  @@map("onetimecode")
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])

  @@map("passwordresettoken")
}

model CreatorProfile {
  id                 String                      @id @default(uuid())
  userId             String                      @unique
  handle             String                      @unique
  displayName        String
  headline           String?
  bio                String?
  focusCategories    Json?
  verificationStatus CreatorVerificationStatus   @default(pending)
  followersCount     Int                         @default(0)
  averageRating      Decimal?                    @db.Decimal(5, 2)
  payoutEligible     Boolean                     @default(false)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  user               User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  verificationReviews CreatorVerificationReview[]

  @@index([verificationStatus, payoutEligible])

  @@map("creatorprofile")
}

model Category {
  id              String            @id @default(uuid())
  slug            String            @unique
  name            String            @unique
  description     String?
  icon            String?
  status          CategoryStatus    @default(active)
  createdById     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdBy       User?             @relation("CategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  liveSessions    LiveSession[]
  premiumContents PremiumContent[]
  classes         LearningClass[]

  @@index([createdById])

  @@map("category")
}

model LiveSession {
  id              String             @id @default(uuid())
  creatorId       String
  categoryId      String?
  title           String
  description     String?
  price           Decimal            @db.Decimal(12, 2)
  currency        String             @default("USD")
  isPaid          Boolean            @default(false)
  visibility      LiveVisibility     @default(public)
  status          LiveSessionStatus  @default(draft)
  scheduledFor    DateTime?
  publishedAt     DateTime?
  startedAt       DateTime?
  endedAt         DateTime?
  roomId          String             @unique @default(uuid())
  roomMetadata    Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  creator         User               @relation("UserLiveSessions", fields: [creatorId], references: [id])
  category        Category?          @relation(fields: [categoryId], references: [id])
  participants    LiveParticipant[]
  chatMessages    LiveChatMessage[]

  @@index([creatorId, status])
  @@index([categoryId, scheduledFor])
  @@index([status, visibility, scheduledFor])

  @@map("livesession")
}

model LiveParticipant {
  id                String      @id @default(uuid())
  liveSessionId     String
  userId            String
  joinedAt          DateTime    @default(now())
  leftAt            DateTime?
  attendanceSeconds Int         @default(0)
  liveSession       LiveSession @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([liveSessionId, userId])
  @@index([userId, joinedAt])

  @@map("liveparticipant")
}

model PremiumContent {
  id             String               @id @default(uuid())
  creatorId      String
  categoryId     String?
  title          String
  excerpt        String?
  description    String?
  price          Decimal              @db.Decimal(12, 2)
  currency       String               @default("USD")
  isPaid         Boolean              @default(true)
  status         PremiumContentStatus @default(draft)
  previewAsset   String?
  contentAsset   String?
  publishedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  creator        User                 @relation("UserPremiumContents", fields: [creatorId], references: [id])
  category       Category?            @relation(fields: [categoryId], references: [id])

  @@index([creatorId, status])
  @@index([categoryId, publishedAt])
  @@index([status, publishedAt])

  @@map("premiumcontent")
}

model LearningClass {
  id             String         @id @default(uuid())
  creatorId      String
  categoryId     String?
  title          String
  description    String?
  price          Decimal        @db.Decimal(12, 2)
  currency       String         @default("USD")
  isPaid         Boolean        @default(true)
  status         ClassStatus    @default(draft)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  creator        User           @relation("UserClasses", fields: [creatorId], references: [id])
  category       Category?      @relation(fields: [categoryId], references: [id])
  lessons        ClassLesson[]
  enrollments    Enrollment[]

  @@map("classes")
  @@index([creatorId, status])
  @@index([categoryId, startsAt])
}

model ClassLesson {
  id            String         @id @default(uuid())
  classId       String
  title         String
  description   String?
  orderIndex    Int
  isPreview     Boolean        @default(false)
  assetUrl      String?
  scheduledFor  DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  learningClass LearningClass  @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, orderIndex])

  @@map("classlesson")
}

model Enrollment {
  id             String           @id @default(uuid())
  classId        String
  userId         String
  accessGrantId  String?
  status         EnrollmentStatus @default(pending)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  learningClass  LearningClass    @relation(fields: [classId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessGrant    AccessGrant?     @relation(fields: [accessGrantId], references: [id], onDelete: SetNull)

  @@unique([classId, userId])
  @@index([userId, status])
  @@index([accessGrantId])

  @@map("enrollment")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  creatorId   String
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  creator     User     @relation("CreatorFollower", fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([followerId, creatorId])

  @@map("follow")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  body        String
  data        Json?
  scheduledFor DateTime?
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([scheduledFor, readAt])

  @@map("notification")
}

model AccessGrant {
  id               String                 @id @default(uuid())
  userId           String
  grantedById      String?
  targetType       AccessGrantTargetType
  targetId         String
  status           AccessGrantStatus      @default(active)
  sourceReference  String?               @unique
  price            Decimal?               @db.Decimal(12, 2)
  currency         String?
  riskScore        Decimal?               @db.Decimal(5, 2)
  expiresAt        DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  user             User                   @relation("AccessGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy        User?                  @relation("AccessGrantGrantor", fields: [grantedById], references: [id])
  enrollments      Enrollment[]

  @@index([userId, targetType, targetId, status])
  @@index([targetType, targetId, status])

  @@map("accessgrant")
}

model Review {
  id          String           @id @default(uuid())
  authorId    String
  targetType  ReviewTargetType
  targetId    String
  rating      Int
  comment     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  author      User             @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([authorId, targetType, targetId])
  @@index([targetType, targetId, createdAt])

  @@map("review")
}

model Report {
  id          String            @id @default(uuid())
  reporterId  String
  targetType  ReportTargetType
  targetId    String
  reason      String
  details     String?
  status      ModerationStatus  @default(open)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  reporter    User              @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  moderationActions ModerationAction[]

  @@index([targetType, targetId, status])
  @@index([status, createdAt])

  @@map("report")
}


model LiveChatMessage {
  id            String                @id @default(uuid())
  liveSessionId String
  senderId      String
  body          String
  status        LiveChatMessageStatus @default(active)
  metadata      Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  liveSession   LiveSession           @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  sender        User                  @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([liveSessionId, createdAt])
  @@index([senderId, createdAt])

  @@map("livechatmessage")
}

model CreatorVerificationReview {
  id               String                     @id @default(uuid())
  creatorProfileId String
  reviewerId       String
  decision         VerificationReviewDecision
  notes            String?
  createdAt        DateTime                   @default(now())
  creatorProfile   CreatorProfile             @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  reviewer         User                       @relation("CreatorVerificationReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([creatorProfileId, createdAt])
  @@index([reviewerId, createdAt])

  @@map("creatorverificationreview")
}

model ModerationAction {
  id          String                     @id @default(uuid())
  moderatorId String
  reportId    String?
  targetType  ModerationActionTargetType
  targetId    String
  action      ModerationActionType
  reason      String
  metadata    Json?
  createdAt   DateTime                   @default(now())
  moderator   User                       @relation("ModerationActor", fields: [moderatorId], references: [id], onDelete: Restrict)
  report      Report?                    @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId, createdAt])
  @@index([moderatorId, createdAt])
  @@index([reportId])

  @@map("moderationaction")
}

// ============ Global Platform Models ============

model PaymentMethod {
  id            String           @id @default(uuid())
  userId        String
  type          PaymentMethodType
  provider      PaymentProvider
  country       String?          @db.Char(2)
  lastFour      String?          @db.Char(4)
  brand         String?
  isDefault     Boolean          @default(false)
  isActive      Boolean          @default(true)
  expiresAt     DateTime?
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([type, country])
  @@unique([userId, provider, type, lastFour])

  @@map("paymentmethod")
}

model PaymentProviderConfig {
  id                String   @id @default(uuid())
  provider          PaymentProvider @unique
  countries         Json     // ["US", "GB", "NG", ...]
  paymentTypes      Json     // ["credit_card", "paypal", ...]
  fees              Json     // {"fixed": 0.30, "percentage": 2.9}
  settingsOverride  Json?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isActive])

  @@map("paymentproviderconfig")
}

model AuditLog {
  id               String                  @id @default(uuid())
  actorId          String?
  actorRole        UserRole?
  action           String
  actionCategory   AuditActionCategory
  resource         String
  resourceType     String?
  resourceId       String?
  status           String                  @default("success") // success, failure, pending
  statusCode       Int?
  description      String?
  ipAddress        String?
  userAgent        String?
  metadata         Json?
  changes          Json?                   // {before: {...}, after: {...}}
  errorMessage     String?
  duration         Int?                    // milliseconds
  createdAt        DateTime                @default(now())
  timestamp        DateTime                @default(now())
  actor            User?                   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, timestamp])
  @@index([action, timestamp])
  @@index([actionCategory, status])
  @@index([resourceType, resourceId])
  @@index([status])
  @@index([timestamp])

  @@map("auditlog")
}

model SessionAuditLog {
  id              String   @id @default(uuid())
  userId          String
  sessionId       String?  // JWT jti claim
  eventType       String   // login_success, login_failure, logout, token_refresh, etc
  ipAddress       String
  userAgent       String
  country         String?  @db.Char(2)
  city            String?
  isSuspicious    Boolean  @default(false)
  metadata        Json?
  timestamp       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType])
  @@index([eventType, timestamp])
  @@index([isSuspicious])
  @@index([userId, timestamp])

  @@map("sessionauditlog")
}

model PaymentAuditLog {
  id              String   @id @default(uuid())
  paymentId       String
  userId          String
  paymentType     String   // purchase, refund, payout, adjustment
  action          String   // initiated, processing, completed, failed, refunded
  previousStatus  String?
  newStatus       String?
  amount          Decimal? @db.Decimal(19, 2)
  currency        String?  @db.Char(3)
  paymentMethod   String?
  paymentProvider String?
  failureReason   String?
  ipAddress       String?
  metadata        Json?
  timestamp       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([paymentId, timestamp])
  @@index([userId, action])
  @@index([action, timestamp])
  @@index([userId, timestamp])

  @@map("paymentauditlog")
}

model ContentAccessAuditLog {
  id              String   @id @default(uuid())
  userId          String
  contentType     String   // live_session, premium_content, class, lesson
  contentId       String
  creatorId       String?
  accessType      String   // view, stream, download, share
  accessDuration  Int?     // seconds
  bytesTransferred Int?
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  timestamp       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, contentType])
  @@index([contentType, contentId])
  @@index([creatorId, timestamp])
  @@index([userId, timestamp])

  @@map("contentaccessauditlog")
}

model CountryPaymentReconciliation {
  id                   String   @id @default(uuid())
  country              String   @db.Char(2)
  month                Int      // 1-12
  year                 Int
  grossRevenue         Decimal  @default(0) @db.Decimal(19, 2)
  platformCommission   Decimal  @default(0) @db.Decimal(19, 2)
  creatorEarnings      Decimal  @default(0) @db.Decimal(19, 2)
  totalTransactions    BigInt   @default(0)
  failedTransactions   BigInt   @default(0)
  refundedAmount       Decimal  @default(0) @db.Decimal(19, 2)
  averageTransactionValue Decimal? @db.Decimal(19, 2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([country, month, year])
  @@index([country])
  @@index([year, month])

  @@map("countrypaymentreconciliation")
}
