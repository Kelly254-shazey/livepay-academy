{
  "name": "livegate-frontend-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "mobile"
  ],
  "devDependencies": {
    "glob": "^10.3.0",
    "tar": "^6.2.0"
  },
  "scripts": {
    "dev:web": "npm --workspace ./web run dev",
    "build:web": "npm --workspace ./web run build",
    "dev:mobile": "npm --workspace ./mobile run start",
    "build:mobile": "npm --workspace ./mobile run build",
    "android": "npm --workspace ./mobile run android",
    "ios": "npm --workspace ./mobile run ios",
    "eas:build:android": "npm --workspace ./mobile run eas build -p android --profile preview",
    "eas:build:ios": "npm --workspace ./mobile run eas build -p ios --profile preview",
    "eas:build:all": "npm --workspace ./mobile run eas build --profile preview",
    "typecheck": "npm --workspace ./web run typecheck && npm --workspace ./mobile run typecheck",
    "typecheck:web": "npm --workspace ./web run typecheck",
    "typecheck:mobile": "npm --workspace ./mobile run typecheck"
  },
  "dependencies": {
    "react-native-worklets": "^0.8.1"
  }
}
