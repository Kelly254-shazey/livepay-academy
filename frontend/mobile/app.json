{
  "expo": {
    "name": "LiveGate",
    "slug": "livegate-mobile",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "livegate",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4EFE7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.livegate.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "LiveGate uses the camera when a content creator starts a live session.",
        "NSMicrophoneUsageDescription": "LiveGate uses the microphone when a content creator goes live with audio enabled.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F4EFE7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.livegate.mobile",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "LiveGate uses the camera when a content creator starts a live session.",
          "microphonePermission": "LiveGate uses the microphone when a content creator goes live with audio enabled.",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "storeListing": {
        "androidPackage": "com.livegate.mobile",
        "iosBundleIdentifier": "com.livegate.mobile"
      },
      "router": {},
      "eas": {
        "projectId": "43aa178a-fad3-4afe-b95b-d228b043e4cd"
      }
    }
  }
}
