{
  "cli": {
    "version": ">= 16.0.0"
  },
  "projectId": "livegate-mobile",
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.x",
      "npm": "10.x"
    },
    "preview": {
      "distribution": "internal",
      "node": "20.x",
      "npm": "10.x"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production"
      },
      "node": "20.x",
      "npm": "10.x"
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      },
      "ios": {}
    }
  }
}
